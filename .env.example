# Copiá este archivo a .env y completá tus valores. .env nunca se sube a git.

# Números de WhatsApp permitidos para usar el bot (separados por coma si son
# varios). Podés poner solo el número con código de país, sin "+" ni espacios
# (ej: 5491122334455), o el JID completo. CUALQUIER OTRO NÚMERO SERÁ IGNORADO.
# Esta es la única barrera de seguridad real del bot: es obligatoria.
ALLOWED_NUMBERS=

# Palabra clave para activar el menú (opcional, default "celestia")
PALABRA_CLAVE=celestia

# Plugin "Local REST API" de Obsidian (Configuración del plugin > API Key)
OBSIDIAN_API_KEY=
OBSIDIAN_URL=https://127.0.0.1:27124

# Ollama corriendo en local con el modelo ya descargado (ollama pull <modelo>)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# whisper.cpp compilado, con el modelo descargado (requiere ffmpeg instalado)
WHISPER_PATH=/ruta/a/whisper.cpp
WHISPER_MODEL=models/ggml-base.bin
